# ---- Application ----
APP_ENV=development
PORT=8080

# ---- Database ----
# When running via docker compose, DB_HOST should be the postgres service name.
DB_HOST=localhost
DB_PORT=5432
DB_USER=sumly
DB_PASSWORD=sumly
DB_NAME=sumly
DB_SSLMODE=disable

# ---- Auth ----
# IMPORTANT: change this to a long random string in production.
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_HOURS=72

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- App ----
# Public URL of the frontend; used to build password reset links.
APP_URL=http://localhost:5173

# ---- Email (password reset) ----
# Leave SMTP_HOST empty to log emails to the server console instead of sending
# (the forgot-password flow stays testable without an email provider).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sumly <no-reply@sumly.uz>

# ---- Receipt scanner (AI) ----
# Claude API key for scanning payment receipts in the expense form.
# Leave empty to disable the feature. Get a key at https://platform.claude.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Local AI (voice parsing fallback + financial advisor) ----
# A running Ollama server. From Docker use host.docker.internal; running the
# backend directly on your machine use http://localhost:11434.
# Leave OLLAMA_URL empty to disable AI paths (rule-based fallbacks still work).
OLLAMA_URL=http://host.docker.internal:11434
# General 7B instruct model — best Uzbek/Russian quality (pull: ollama pull
# qwen2.5:7b). Use qwen2.5:3b for faster, lighter (but rougher) responses.
OLLAMA_MODEL=qwen2.5:7b
# Let the LLM phrase the dashboard advice. The numbers are pre-computed and
# passed to the model, so figures stay exact even on a small model; if the model
# is off or returns broken text, a clear deterministic advisor is used instead.
OLLAMA_ADVISOR=true
