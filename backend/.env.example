# ---- Application ----
APP_ENV=development
PORT=8080

# ---- Database ----
# When running via docker compose, DB_HOST should be the postgres service name.
DB_HOST=localhost
DB_PORT=5432
DB_USER=sumly
DB_PASSWORD=sumly
DB_NAME=sumly
DB_SSLMODE=disable

# ---- Auth ----
# IMPORTANT: change this to a long random string in production.
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_HOURS=72

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
