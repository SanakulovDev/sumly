# Base URL for API requests.
# Leave empty to use same-origin relative "/api" paths (recommended):
#   - local dev: Vite proxies /api -> http://localhost:8080
#   - docker:    nginx proxies /api -> backend service
# Set to an absolute URL only if the API lives on a different origin.
VITE_API_BASE_URL=

# Used only by `npm run dev` to choose the proxy target.
VITE_DEV_API_TARGET=http://localhost:8080
