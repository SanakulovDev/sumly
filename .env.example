# Root environment for `docker compose up --build`.
# Copy to `.env` and adjust as needed. All values have safe defaults, so the
# stack runs even without this file.

# ---- Ports (host side) ----
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_PORT=5432

# ---- Application ----
APP_ENV=production

# ---- Database ----
DB_USER=sumly
DB_PASSWORD=sumly
DB_NAME=sumly

# ---- Auth ----
# IMPORTANT: set a long random value before deploying anywhere real.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=72

# ---- CORS ----
CORS_ALLOW_ORIGINS=http://localhost:3000
